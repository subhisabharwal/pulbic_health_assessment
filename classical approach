def map_scheme(x):
    if pd.isna(x):
        return 'No Scheme'

    if 'ayush' in x:
        return 'Ayushman Bharat'

    elif 'arogya' in x or 'aarogya' in x:
        return 'Aarogyasri'

    elif 'biju' in x or 'bsky' in x:
        return 'Biju Swasthya Yojana'

    elif 'swasthya sathi' in x or 'sathi' in x:
        return 'Swasthya Sathi'

    elif 'chiranjeevi' in x or 'chiranjivi' in x:
        return 'Chiranjeevi Yojana'

    elif 'amrit' in x:
        return 'Atal Amrit'

    elif 'esi' in x or 'esic' in x:
        return 'ESI'

    elif 'cghs' in x:
        return 'CGHS'

    elif 'insurance' in x:
        return 'Private Insurance'

    else:
        return 'Other Scheme'

