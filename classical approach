import matplotlib.pyplot as plt
import seaborn as sns
import pandas as pd
from sklearn.cluster import KMeans

sns.set_style('white')  # removed grid
sns.set_context('talk')

df_clean['used_insurance'] = df_clean['b6f'] > 0

state_data = df_clean.groupby('state_name').agg(
    utilised=('used_insurance', 'mean'),
    satisfaction_score=('overall_sat', 'mean')
).reset_index()


X = state_data[['utilised', 'satisfaction_score']]
kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
state_data['cluster'] = kmeans.fit_predict(X)


plt.figure(figsize=(10,6))

sns.scatterplot(
    data=state_data,
    x='utilised',
    y='satisfaction_score',
    hue='cluster',
    palette='Set1',
    s=100
)

# Labels
for i in range(len(state_data)):
    plt.text(
        state_data['utilised'].iloc[i] + 0.002,
        state_data['satisfaction_score'].iloc[i] + 0.002,
        state_data['state_name'].iloc[i],
        fontsize=8
    )

plt.title('State Clusters: Satisfaction vs Utilisation')
plt.xlabel('Utilisation Rate')
plt.ylabel('Average Satisfaction Score')
plt.legend(title='Cluster')

plt.tight_layout()
plt.show()
